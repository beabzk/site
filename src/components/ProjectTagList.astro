---
interface Props {
	tags: string[];
}

const { tags } = Astro.props;
---

<ul class="project-tags">
	{tags.map((tag) => <li>{tag}</li>)}
</ul>

<style>
	.project-tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.55rem;
		list-style: none;
		margin: 0;
		padding: 0;
	}

	.project-tags li {
		padding: 0.3rem 0.72rem;
		border-radius: 999px;
		background: rgba(var(--gray), 0.1);
		border: 1px solid var(--surface-border);
		font-size: 0.82rem;
		font-weight: 600;
	}
</style>
