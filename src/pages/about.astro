---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SOCIAL_LINKS, SITE_AUTHOR, SITE_TITLE } from '../consts';

---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title={`About - ${SITE_TITLE}`}
			description="About beabzk, a full-stack developer focused on practical software and clear systems."
		/>
		<style>
			.about-grid {
				display: grid;
				grid-template-columns: minmax(0, 1.4fr) minmax(280px, 0.8fr);
				gap: 1.5rem;
			}
			.story,
			.sidebar {
				padding: 1.75rem;
			}
			.story p:last-child {
				margin-bottom: 0;
			}
			.sidebar {
				display: grid;
				gap: 1rem;
				align-content: start;
			}
			.contact-list {
				display: grid;
				gap: 0.85rem;
				padding: 0;
				margin: 0;
				list-style: none;
			}
			.contact-list a {
				text-decoration: none;
				font-weight: 600;
			}
			@media (max-width: 900px) {
				.about-grid {
					grid-template-columns: 1fr;
				}
			}
		</style>
	</head>
	<body>
		<Header/>
		<main id="main">
			<div class="section-heading">
				<div>
					<p class="eyebrow">About</p>
					<h1>{SITE_AUTHOR}</h1>
				</div>
			</div>

			<section class="about-grid">
				<div class="story surface-card">
					<p class="lede">
						Hey, I&apos;m {SITE_AUTHOR}. I’m a student and a hobbyist. I study mechanical engineering, but I spend a lot of my free time programming. I build things to learn how they work.
					</p>
					<p>
						My background is in the physical world, but I treat code as just another tool in the toolbox. I write software to automate my routines, build utilities for things I enjoy, and fix daily annoyances. I don't claim to be an expert in either field yet, but I like solving my own problems.
					</p>
					<p>
						This site is a small record of that work: projects I&apos;ve built, notes from learning in public, and the tools I use to fix my daily annoyances.
					</p>
				</div>

				<aside class="sidebar">
					<div class="surface-card" style="padding: 1.5rem;">
						<p class="eyebrow">Contact</p>
						<ul class="contact-list">
							{SOCIAL_LINKS.map((link) => (
								<li>
									<a href={link.href} target={link.href.startsWith('mailto:') ? undefined : '_blank'} rel="noopener noreferrer">
										{link.label}
									</a>
								</li>
							))}
						</ul>
					</div>
				</aside>
			</section>
		</main>
		<Footer />
	</body>
</html>
