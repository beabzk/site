---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Not Found - ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
		<style>
			.not-found {
				min-height: 60vh;
				display: grid;
				place-items: center;
			}
			.panel {
				max-width: 42rem;
				padding: 2rem;
				text-align: center;
			}
			.code {
				margin: 0 0 1rem 0;
				font-size: 0.85rem;
				letter-spacing: 0.22em;
				text-transform: uppercase;
				color: var(--accent);
				font-weight: 700;
			}
			.actions {
				display: flex;
				justify-content: center;
				flex-wrap: wrap;
				gap: 0.75rem;
				margin-top: 1.5rem;
			}
		</style>
	</head>
	<body>
		<Header />
		<main id="main">
			<section class="not-found">
				<div class="panel surface-card">
					<p class="code">404</p>
					<h1>That page does not exist.</h1>
					<p class="lede" style="margin: 1rem auto 0 auto;">
						The route you tried is not part of this version of the site. Use one of the main sections below instead.
					</p>
					<div class="actions">
						<a class="button-link button-link-primary" href="/">Go home</a>
						<a class="button-link button-link-secondary" href="/projects">Browse projects</a>
						<a class="button-link button-link-secondary" href="/blog">Read the blog</a>
					</div>
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>
