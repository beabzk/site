---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import ProjectTagList from '../components/ProjectTagList.astro';
import { Icon } from 'astro-icon/components';

type Props = CollectionEntry<'projects'>['data'];
type ProjectLink = {
	href: string;
	label: string;
	icon: string;
};

const {
	title,
	description,
	date,
	tags,
	github,
	demo,
	docs,
	npm,
	featured,
	status,
	category,
} = Astro.props;

const links = [
	github && { href: github, label: 'Source', icon: 'simple-icons:github' },
	demo && { href: demo, label: 'Demo', icon: 'mdi:open-in-new' },
	docs && { href: docs, label: 'Docs', icon: 'mdi:open-in-new' },
	npm && { href: npm, label: 'Package', icon: 'mdi:open-in-new' },
].filter((link): link is ProjectLink => Boolean(link));
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
		<style>
			.project-shell {
				display: grid;
				gap: 2rem;
			}
			.project-header,
			.project-sidebar {
				padding: 1.75rem;
			}
			.project-header {
				display: grid;
				gap: 1rem;
			}
			.project-meta {
				display: flex;
				flex-wrap: wrap;
				gap: 0.75rem 1rem;
				color: var(--footer-text);
				font-size: 0.92rem;
			}
			.project-grid {
				display: grid;
				grid-template-columns: minmax(0, 1.45fr) minmax(260px, 0.75fr);
				gap: 1.5rem;
				align-items: start;
			}
			.project-prose {
				padding: 1.75rem;
			}
			.project-prose :global(p:last-child) {
				margin-bottom: 0;
			}
			.link-list {
				display: grid;
				gap: 0.75rem;
			}
			.project-link {
				display: inline-flex;
				align-items: center;
				justify-content: space-between;
				gap: 0.75rem;
				padding: 0.9rem 1rem;
				border-radius: 16px;
				background: var(--card-bg);
				border: 1px solid var(--surface-border);
				text-decoration: none;
				font-weight: 700;
			}
			.project-link span {
				display: inline-flex;
				align-items: center;
				gap: 0.5rem;
			}
			.sidebar-block + .sidebar-block {
				margin-top: 1.1rem;
			}
			.sidebar-block h3 {
				font-size: 0.84rem;
				text-transform: uppercase;
				letter-spacing: 0.14em;
				margin-bottom: 0.8rem;
				color: var(--accent);
			}
			.status-pill {
				display: inline-flex;
				padding: 0.4rem 0.8rem;
				border-radius: 999px;
				background: rgba(var(--gray), 0.1);
				border: 1px solid var(--surface-border);
				font-weight: 700;
			}
			@media (max-width: 900px) {
				.project-grid {
					grid-template-columns: 1fr;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main id="main">
			<div class="project-shell">
				<Breadcrumb items={[
					{ label: 'Home', href: '/' },
					{ label: 'Projects', href: '/projects' },
					{ label: title, href: Astro.url.pathname },
				]} />
				<header class="project-header surface-card">
					<p class="eyebrow">Project</p>
					<div class="project-meta">
						<span><FormattedDate date={date} /></span>
						<span>{status}</span>
						{category && <span>{category}</span>}
						{featured && <span>Featured</span>}
					</div>
					<h1>{title}</h1>
					<p class="lede">{description}</p>
				</header>

				<div class="project-grid">
					<article class="project-prose surface-card">
						<slot />
					</article>

					<aside class="project-sidebar surface-card">
						{links.length > 0 && (
							<section class="sidebar-block">
								<h3>Links</h3>
								<div class="link-list">
									{
										links.map((link) => (
											<a class="project-link" href={link.href} target="_blank" rel="noopener noreferrer">
												<span>
													<Icon name={link.icon} width={18} height={18} aria-hidden="true" />
													{link.label}
												</span>
												<Icon name="mdi:open-in-new" width={18} height={18} aria-hidden="true" />
											</a>
										))
									}
								</div>
							</section>
						)}

						<section class="sidebar-block">
							<h3>Status</h3>
							<div class="status-pill">{status}</div>
						</section>

						{category && (
							<section class="sidebar-block">
								<h3>Category</h3>
								<p>{category}</p>
							</section>
						)}

						<section class="sidebar-block">
							<h3>Tech Stack</h3>
							<ProjectTagList tags={tags} />
						</section>
					</aside>
				</div>
			</div>
		</main>
		<Footer />
	</body>
</html>
